{
  "expo": {
    "name": "TrackApp",
    "slug": "trackapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "trackapp",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#1A1A2E"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bugra.trackapp"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1A1A2E"
      },
      "package": "com.bugra.trackapp"
    },
    "web": {
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "TrackApp gebruikt je locatie om flitsers, meldingen en waarschuwingen op de kaart te tonen."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/logo.png",
          "color": "#FF6B00"
        }
      ]
    ]
  }
}
